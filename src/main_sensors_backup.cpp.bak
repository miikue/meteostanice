#include <Arduino.h>
#include <Wire.h>
#include <Adafruit_BME280.h>
#include <Adafruit_LTR390.h>

TwoWire Wire2 = TwoWire(1);

Adafruit_BME280 bme1;
Adafruit_LTR390 ltr1 = Adafruit_LTR390();

Adafruit_BME280 bme2;
Adafruit_LTR390 ltr2 = Adafruit_LTR390();

void setup() {
  Serial.begin(115200);
  while (!Serial);

  pinMode(35, OUTPUT);
  pinMode(4, OUTPUT);
  digitalWrite(4, HIGH);
  pinMode(47, OUTPUT);
  digitalWrite(47, HIGH);
  delay(1000);

  Wire.begin(42, 2);
  Wire2.begin(17, 18);

  if (!bme1.begin(0x77, &Wire)) Serial.println("BME1 chyba!");
  if (!ltr1.begin(&Wire)) Serial.println("LTR1 chyba!");
  
  if (!bme2.begin(0x77, &Wire2)) Serial.println("BME2 chyba!");
  if (!ltr2.begin(&Wire2)) Serial.println("LTR2 chyba!");

  ltr1.setMode(LTR390_MODE_UVS);
  ltr2.setMode(LTR390_MODE_UVS);

  ltr1.setGain(LTR390_GAIN_3);
  ltr1.setResolution(LTR390_RESOLUTION_18BIT);
  
  ltr2.setGain(LTR390_GAIN_3);
  ltr2.setResolution(LTR390_RESOLUTION_18BIT);
}

void loop() {
  Serial.println("\n--- Wire 1 (42, 2) ---");
  Serial.print("BME280 Temp: "); Serial.println(bme1.readTemperature());
  Serial.print("LTR390 UV:   "); Serial.println(ltr1.readUVS());

  Serial.println("--- Wire 2 (17, 18) ---");
  Serial.print("BME280 Temp: "); Serial.println(bme2.readTemperature());
  Serial.print("LTR390 UV:   "); Serial.println(ltr2.readUVS());

  delay(3000);
}